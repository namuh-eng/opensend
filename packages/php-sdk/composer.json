{
  "name": "opensend/opensend-php",
  "description": "First-party PHP SDK for OpenSend email APIs.",
  "type": "library",
  "license": "Elastic-2.0",
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "OpenSend\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "OpenSend\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml"
  }
}
