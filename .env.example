# Copy this file to .env and fill in your values.
#
# Convention:
#   - Uncommented lines = required for local dev to work end-to-end.
#   - Commented lines   = optional, or only needed for specific features /
#                          staging / production.

# ─────────────────────────────────────────────────────────────────
# Database (required)
# ─────────────────────────────────────────────────────────────────
# If you run app/scripts on your host machine, leave the localhost URL as-is.
# Docker Compose services use their own internal DATABASE_URL automatically.
DATABASE_URL=postgresql://opensend:opensend@localhost:5432/opensend
# Remote Postgres example (RDS / Supabase / Neon):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Docker Compose Postgres password — REQUIRED when running `docker compose up`.
# `docker-compose.yml` no longer provides a fallback: if this is unset, compose
# fails fast at boot. The default value below matches DATABASE_URL above so
# `cp .env.example .env && docker compose up` works out of the box for local
# dev. ALWAYS pick a strong unique value (and update DATABASE_URL to match) for
# anything that leaves your laptop.
POSTGRES_PASSWORD=opensend
# If port 5432 is taken on your host, change BOTH this and DATABASE_URL.
# POSTGRES_PORT=5432

# ─────────────────────────────────────────────────────────────────
# Auth (required)
# ─────────────────────────────────────────────────────────────────
# Local-only session signing placeholder for localhost evaluation. Replace
# before any shared, staging, or production deploy. Startup checks reject this
# placeholder when BETTER_AUTH_URL/NEXT_PUBLIC_APP_URL is not localhost.
#   openssl rand -hex 32
BETTER_AUTH_SECRET=local-dev-better-auth-secret-replace-before-production
# Better Auth callback base URL.
BETTER_AUTH_URL=http://localhost:3015
# Public URL the frontend uses. Must match BETTER_AUTH_URL for local dev.
NEXT_PUBLIC_APP_URL=http://localhost:3015
# Optional public tracking endpoint. CNAME DNS guidance points custom tracking
# subdomains at this host (or NEXT_PUBLIC_APP_URL when unset).
# TRACKING_BASE_URL=https://your.app
# Optional explicit CNAME target if it differs from TRACKING_BASE_URL's host.
# TRACKING_CNAME_TARGET=your.app

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────
# App port (Docker Compose only — Next.js dev server uses bun run dev)
# ─────────────────────────────────────────────────────────────────
# PORT=3015

# ─────────────────────────────────────────────────────────────────
# AWS SES — email sending (required to actually send mail)
# ─────────────────────────────────────────────────────────────────
# Locally these are picked up from ~/.aws/credentials. Set them
# explicitly for Docker / production.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# Optional SES/SNS destination for provider delivery feedback. Point this SNS
# topic at the ingester's /events/ses endpoint in staging/production.
# SES_EVENTS_SNS_TOPIC_ARN=
# Optional SES/SNS destination for inbound receiving. Point this SNS topic at
# the ingester's /events/inbound/ses-s3 endpoint before enabling receiving.
# SES_INBOUND_SNS_TOPIC_ARN=
# Optional multi-region inbound receiving topics. JSON object keys are SES
# receiving regions; values are same-region SNS topic ARNs. Region-specific
# variables like SES_INBOUND_SNS_TOPIC_ARN_US_EAST_1 also work.
# SES_INBOUND_SNS_TOPIC_ARNS={"us-east-1":"arn:aws:sns:us-east-1:123456789012:opensend-inbound-mail"}
#
# NOTE: New AWS accounts are in SES *sandbox* mode and can only send
# to verified addresses. Request production access in the SES console.

# ─────────────────────────────────────────────────────────────────
# AWS S3 — email attachment storage (required only for attachments)
# ─────────────────────────────────────────────────────────────────
# S3_BUCKET_NAME=

# ─────────────────────────────────────────────────────────────────
# Cloudflare DNS — auto-configure DKIM/SPF/DMARC when adding domains
# ─────────────────────────────────────────────────────────────────
# Get a token at https://dash.cloudflare.com/profile/api-tokens
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=

# ─────────────────────────────────────────────────────────────────
# Rate limiting + cache backend (recommended for staging/production)
# ─────────────────────────────────────────────────────────────────
# Outside Docker Compose, RATE_LIMIT_BACKEND defaults to disabled for single-process dev.
# Docker Compose sets RATE_LIMIT_BACKEND=redis and REDIS_URL=redis://redis:6379 by default.
# RATE_LIMIT_BACKEND=disabled # local single-process only; no API rate limiting
# RATE_LIMIT_BACKEND=redis    # required for shared/staging/production and Compose
# OPENSEND_APP_REPLICAS=1     # set >1 when running multiple app containers; warns unless backend=redis
# Use the TLS-enabled endpoint (rediss://...) when RATE_LIMIT_BACKEND=redis outside Compose.
# REDIS_URL backs:
#   - Rate limiting (app, when RATE_LIMIT_BACKEND=redis)
#   - API-key auth caching (app)
#   - Domain metadata caching (app)
#   - Domain cache invalidation (ingester — optional; invalidations are
#     skipped with a warn log when unset, TTL expiry still guarantees
#     eventual consistency)
# REDIS_URL=rediss://default:password@your-cache-endpoint:6379

# ─────────────────────────────────────────────────────────────────
# Background jobs — SQS / EventBridge send pipeline
# ─────────────────────────────────────────────────────────────────
# Optional locally. Required for the queued send path in staging/prod.
# POST /api/emails persists rows and publishes email.send jobs here.
# Configure the SQS queue with a redrive policy / DLQ for retry exhaustion.
# BACKGROUND_JOBS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/opensend-background
# BACKGROUND_JOBS_EVENT_BUS_NAME=opensend-background-jobs
# BACKGROUND_JOBS_REQUIRE_QUEUE=true
# Set on the ingester/worker process to long-poll SQS.
# BACKGROUND_WORKER_POLL=true
# Optional public status-page probe for ingester/webhook readiness.
# INGESTER_HEALTH_URL=http://localhost:3016/health

# ─────────────────────────────────────────────────────────────────
# Ingester / cron auth tokens
# ─────────────────────────────────────────────────────────────────
# Required in production and Docker Compose. Shared secret between the scheduler/EventBridge and the ingester service for /jobs/* calls.
# The value below is a local-only placeholder so `cp .env.example .env && docker compose up -d` can boot.
# Replace it before any shared, staging, or production deploy:
#   openssl rand -hex 32
# The scheduler sends Authorization: Bearer ${INGESTER_JOB_TOKEN}.
INGESTER_JOB_TOKEN=local-dev-ingester-job-token-replace-before-production
# Optional for local dev, but production /events/inbound rejects requests without it.
# INGESTER_INBOUND_TOKEN=
# Optional allowlist for SES receipt-rule S3 ingestion. Defaults to S3_BUCKET_NAME.
# SES_INBOUND_BUCKET_NAME=
# Optional SES receipt rule set name managed when dashboard receiving is enabled.
# SES_INBOUND_RULE_SET_NAME=opensend-inbound
# Durable scheduler cadence for /jobs/scheduled-emails, /jobs/webhooks, /jobs/domain-verify, and /jobs/billing-overage.
# INGESTER_SCHEDULER_INTERVAL_SECONDS=60
# Bearer token required by /api/cron/* scheduled-email endpoints.
# CRON_AUTH_TOKEN=

# ─────────────────────────────────────────────────────────────────
# Security secrets (REQUIRED in production; dev has fallbacks)
# ─────────────────────────────────────────────────────────────────
# Dedicated HMAC secret for one-click unsubscribe tokens. Must be >=16
# chars in production; compromising other secrets cannot forge tokens.
# UNSUBSCRIBE_SECRET=
# Dedicated HMAC secret for open/click tracking link signatures.
# TRACKING_SECRET=
# AES-256 key (>=32 bytes) used to encrypt webhook signing_secret at rest.
# The value below is a local-only placeholder so Docker Compose can boot.
# Replace it before any shared, staging, or production deploy:
#   openssl rand -hex 32
# When set, new webhooks store only the encrypted envelope; existing rows
# keep working via a legacy-plaintext fallback until rotated.
WEBHOOK_SECRET_ENCRYPTION_KEY=local-dev-webhook-secret-replace-before-production
# AES-256 key used to encrypt integration connector credentials at rest.
# If omitted, integration encryption falls back to WEBHOOK_SECRET_ENCRYPTION_KEY
# for small self-hosted installs; production should set a dedicated key.
# INTEGRATION_SECRET_ENCRYPTION_KEY=
# AES-256 master key for DKIM private-key encryption. Versioned: bump
# DKIM_KEY_VERSION and add DKIM_ENCRYPTION_KEY_V<n> to rotate without
# re-encrypting in place. Default version is 1.
# DKIM_ENCRYPTION_KEY=
# DKIM_ENCRYPTION_KEY_V2=
# DKIM_KEY_VERSION=1
# Better Auth trusted origins (comma-separated). Required in production
# to prevent CSRF from untrusted origins.
# BETTER_AUTH_TRUSTED_ORIGINS=https://app.example.com,https://www.example.com
# Number of trusted reverse-proxy hops in front of the app. The
# right-most-Nth X-Forwarded-For entry is used as the client IP for rate
# limiting. Set to 1 when behind a single proxy (ALB, Cloudflare).
# TRUSTED_PROXY_HOPS=0

# ─────────────────────────────────────────────────────────────────
# SMTP relay profile (optional; Docker Compose only starts it with --profile smtp)
# ─────────────────────────────────────────────────────────────────
# docker compose --profile smtp up -d smtp-relay
# SMTP_RELAY_PORT=2587
# SMTP_RELAY_HOST=0.0.0.0
# SMTP_RELAY_TLS_CERT_PATH=/run/secrets/smtp-cert.pem
# SMTP_RELAY_TLS_KEY_PATH=/run/secrets/smtp-key.pem
# SMTP_RELAY_MAX_MESSAGE_SIZE_BYTES=41943040

# ─────────────────────────────────────────────────────────────────
# Observability
# ─────────────────────────────────────────────────────────────────
# Override the CloudWatch Embedded Metric Format namespace (default: OpenSend).
# CLOUDWATCH_METRICS_NAMESPACE=OpenSend

# Self-hosters: ALL telemetry below is OFF BY DEFAULT.
# OpenSend makes ZERO outbound calls unless these are set.
# See docs/privacy.md for what is collected when configured.

# Sentry (errors + performance) — server/edge runtime
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# Build-time only — used by `withSentryConfig` to upload source maps
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# Sentry (errors + performance) — browser runtime
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
# NEXT_PUBLIC_SENTRY_RELEASE=
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0
# NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.0

# PostHog (product analytics + session replay + flags)
# Public key — safe to expose to the browser.
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Server-side capture from API routes / scheduled workers (optional)
# POSTHOG_API_KEY=
# POSTHOG_HOST=https://us.i.posthog.com

# ─────────────────────────────────────────────────────────────────
# Billing (optional, off by default)
# ─────────────────────────────────────────────────────────────────
# Self-hosters leave BILLING_BACKEND unset (or "disabled") and never touch Stripe.
# The hosted namuh.co deployment sets BILLING_BACKEND=stripe and provides the keys below.
# When BILLING_BACKEND != "stripe" or STRIPE_SECRET_KEY is missing, all paywall code
# paths short-circuit to "disabled" and no Stripe SDK calls are made.
# BILLING_BACKEND=stripe
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...           # used by the ingester webhook handler
# BILLING_NOTIFICATION_FROM_EMAIL=billing@example.com
# Stripe meter event name used by /jobs/billing-overage. Defaults to opensend_email_overage.
# STRIPE_OVERAGE_METER_EVENT_NAME=opensend_email_overage
# BILLING_SUCCESS_URL=https://your.app/settings/billing?status=success
# BILLING_CANCEL_URL=https://your.app/settings/billing?status=cancelled
